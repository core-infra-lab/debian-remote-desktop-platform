# Copy this file to .env and set secure values before starting.

# Guacamole/Postgres
POSTGRES_DB=guacamole_db
POSTGRES_USER=guacamole_user
POSTGRES_PASSWORD=replace_with_a_strong_password

# VNC desktop
VNC_USER=guac
VNC_PASSWORD=replace_with_a_strong_vnc_password
GEOMETRY=1920x1080
DEPTH=24
AUTO_INSTALL_DEBS=true
VNC_USER=ubuntu
ROOT_PASSWORD=ubuntu

# Optional host-side helpers (used by Makefile outputs)
GUAC_PORT=8081
VNC_PORT=5901
SSH_PORT=4242
