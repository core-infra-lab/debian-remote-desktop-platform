# Full Docker example
# Guacamole, guacd, Postgres, and the VNC desktop all run in Docker.

# Guacamole/Postgres
POSTGRES_DB=guacamole_db
POSTGRES_USER=guacamole_user
POSTGRES_PASSWORD=replace_with_a_strong_password

# Docker VNC desktop
VNC_PASSWORD=replace_with_a_strong_vnc_password
VNC_USER=guac
GEOMETRY=1920x1080
DEPTH=24
AUTO_INSTALL_DEBS=false
ROOT_PASSWORD=

# Published ports on the VM
GUAC_PORT=8081
VNC_PORT=5901
