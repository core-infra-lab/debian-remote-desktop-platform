#!/bin/bash
# Portable xstartup for VNC sessions. Works on WSL/VMs and typical Linux hosts.
# Unset Wayland and runtime dirs so desktop uses X11 created by Xvnc
unset WAYLAND_DISPLAY
unset XDG_RUNTIME_DIR
unset SESSION_MANAGER
unset DBUS_SESSION_BUS_ADDRESS
export DISPLAY=":1"
export XAUTHORITY="$HOME/.Xauthority"
# Load user X resources if present
[ -r "$HOME/.Xresources" ] && xrdb "$HOME/.Xresources"
# Start XFCE under dbus if available, otherwise startxfce4 directly
if command -v dbus-launch >/dev/null 2>&1; then
  exec dbus-launch --exit-with-session startxfce4
else
  exec startxfce4
fi
