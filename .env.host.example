# Host/VM VNC example
# Guacamole, guacd, and Postgres run in Docker.
# The Linux desktop and VNC server run directly on the VM/host.

# Guacamole/Postgres
POSTGRES_DB=guacamole_db
POSTGRES_USER=guacamole_user
POSTGRES_PASSWORD=replace_with_a_strong_password

# VM helper values used by Makefile.host
VM_USER=radandri
VM_IP=10.0.2.15
SSH_PORT=4242
GUAC_PORT=8081

# Host-side VNC server installed by start-vnc-host.sh
HOST_VNC_USER=radandri
HOST_VNC_HOST=host.docker.internal
HOST_VNC_PORT=5901
HOST_VNC_DISPLAY=:1
HOST_VNC_GEOMETRY=1920x1080
HOST_VNC_DEPTH=24
HOST_VNC_PASSWORD=replace_with_a_strong_vnc_password

# Guacamole connection password.
# Keep this equal to HOST_VNC_PASSWORD unless you set the VNC password manually.
VNC_PASSWORD=replace_with_a_strong_vnc_password
